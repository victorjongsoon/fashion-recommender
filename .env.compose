# Docker Compose Environment Variables
# Use these when running: docker-compose --env-file .env.compose up

# Frontend will use these service names within the docker network
VITE_IMAGE_SERVICE_URL=http://image-service:8000
VITE_VTON_SERVICE_URL=http://vton-service:8000

# For local development with docker-compose, you might want:
# VITE_IMAGE_SERVICE_URL=http://localhost:8001
# VITE_VTON_SERVICE_URL=http://localhost:8002
